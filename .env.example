# ── Provider config ──────────────────────────────
# LLM_PROVIDER=openai            # "ollama" (local) or "openai" (cloud API)
#
# OpenAI-compatible provider (OpenRouter, Azure, etc.)
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-oss-20b
#
# Ollama (local)
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# ── Ingestion ────────────────────────────────────
UPLOAD_FOLDER=data/uploads
FAISS_INDEX_PATH=data/faiss_index
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
